# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env

# Hangi LLM kullanılsın: gemini (ücretsiz) | claude (paralı)
LLM_PROVIDER=gemini

# Gemini key — https://aistudio.google.com/apikey (ücretsiz, kredi kartı gerekmez)
GEMINI_API_KEY=AIza-...
GEMINI_MODEL=gemini-2.5-flash

# Claude kullanmak istersen (opsiyonel):
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-opus-4-8

# Lokal embedding modeli (opsiyonel)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Chunk ayarları (opsiyonel)
CHUNK_SIZE=800
CHUNK_OVERLAP=120
