# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env

# --- Sağlayıcı seçimi: groq (ücretsiz, yüksek limit) | gemini | claude ---
LLM_PROVIDER=groq

# Groq — https://console.groq.com (ücretsiz, kart yok; key gsk_... ile başlar)
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant          # cevap üreten model (hızlı + yüksek limit)

# --- Eval yargıcı ---
# Yargıç, üreticiden FARKLI/güçlü bir model olabilir → self-preference bias'ı azaltır.
JUDGE_PROVIDER=groq
JUDGE_MODEL=llama-3.3-70b-versatile      # daha güçlü model = daha güvenilir hakem

# --- Gemini kullanmak istersen (opsiyonel) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key-here    # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Claude kullanmak istersen (opsiyonel, paralı) ---
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-opus-4-8

# Lokal embedding modeli (opsiyonel)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Chunk ayarları (opsiyonel)
CHUNK_SIZE=800
CHUNK_OVERLAP=120
